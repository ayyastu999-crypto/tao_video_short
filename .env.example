# Sao chép file này thành ".env" rồi chỉnh nếu cần. Tất cả đều KHÔNG bắt buộc.

# Model bóc lời: tiny | base | small | medium | large-v3
# (nhỏ = nhanh nhưng kém chính xác; lớn = chính xác nhưng chậm & nặng)
WHISPER_MODEL=small

# Thiết bị chạy: cpu | cuda  (cpu chạy mọi máy; cuda nhanh hơn nhưng cần cài CUDA + cuBLAS)
WHISPER_DEVICE=cpu

# Kiểu tính toán: int8 (nhẹ cho CPU) | float16 (GPU)
WHISPER_COMPUTE=int8

# Lọc khoảng lặng (cần cài onnxruntime). Bật = 1, tắt = 0
WHISPER_VAD=0
